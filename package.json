{
  "name": "omnidm",
  "version": "0.1.0",
  "description": "A multi-platform, multi-player, model-agnostic AI Dungeon Master.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cli": "tsx src/index.ts --adapter cli",
    "discord": "tsx src/index.ts --adapter discord",
    "slack": "tsx src/index.ts --adapter slack",
    "matrix": "tsx src/index.ts --adapter matrix",
    "mattermost": "tsx src/index.ts --adapter mattermost",
    "web": "tsx src/index.ts --adapter web",
    "build": "tsc -p tsconfig.json",
    "build:web": "node scripts/build-web.mjs",
    "start": "node dist/index.js",
    "smoke": "tsx src/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron": "electron electron/main.cjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icons": "node src-tauri/icons/generate-icons.mjs",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:android": "cap run android",
    "cap:ios": "cap run ios"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "matrix-bot-sdk": "^0.8.0",
    "nanoid": "^5.0.7",
    "openai": "^4.67.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "electron": "^33.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "license": "MIT"
}
