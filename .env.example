# ─── OmniDM configuration ───────────────────────────────────────────────────
# Copy this file to ".env" and fill in what you need.

# ── LLM provider (OpenAI-compatible) ─────────────────────────────────────────
# Default points at OpenRouter, which exposes hundreds of models (free + paid,
# including Claude, GPT, Gemini) behind ONE OpenAI-compatible endpoint and one key.
#
# Get a free key at https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=

# Default model. A ":free" model costs nothing and is great for testing.
# Browse the live list in-app with the "/dm models" command.
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Want to use something else instead of OpenRouter? Just change the base URL: ─
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini
#   Anthropic: (use OpenRouter, or add a native adapter later)  LLM_MODEL=anthropic/claude-3.5-sonnet
#   Ollama:    LLM_BASE_URL=http://localhost:11434/v1           LLM_MODEL=llama3.1
#   LM Studio: LLM_BASE_URL=http://localhost:1234/v1            LLM_MODEL=<your-loaded-model>

# ── Discord adapter (only needed for `npm run discord`) ──────────────────────
# Create a bot at https://discord.com/developers/applications, enable the
# "MESSAGE CONTENT INTENT", and paste its token here.
DISCORD_TOKEN=

# ── Misc ─────────────────────────────────────────────────────────────────────
# Where campaign/session data is persisted (JSON files).
DATA_DIR=./data
